# Copy to .env and fill values
# cp .env.example .env

# Core market data (Coinbase Exchange public endpoints)
# Product symbol used for candles/order book/trades
COINBASE_PRODUCT_ID=BTC-USD
# Recent trades lookback window (minutes) for trade-flow features
COINBASE_TRADES_LOOKBACK_MINUTES=60

# Coinalyze (required for funding/liquidations/open interest)
COINALYZE_API_KEY=
COINALYZE_SYMBOL=BTCUSDT_PERP.A

# Macro/event sources (free)
FRED_API_KEY=
BLS_API_KEY=

# Kalshi (required for continuous mispricing runner)
KALSHI_API_BASE=https://api.elections.kalshi.com/trade-api/v2
KALSHI_API_KEY=
# Optional (used by `doctor` single-market check only)
KALSHI_MARKET_TICKER=

# Feature smoothing / regime windows
TRADE_FLOW_SMOOTH_W=4
VOL_RANK_WINDOW=288

# Optional alert webhook for runner alerts
ALERT_WEBHOOK_URL=
